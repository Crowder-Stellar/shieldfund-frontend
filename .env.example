# ─────────────────────────────────────────────────────────────────────────────
# ShieldFund Frontend — environment variables
#
# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Network: TESTNET (default) | MAINNET
VITE_STELLAR_NETWORK=TESTNET

# Contract IDs — printed by shieldfund-contracts/scripts/deploy-testnet.sh
# Paste each value after deploying the contracts.
VITE_TREASURY_VAULT_CONTRACT_ID=
VITE_STREAMING_CONTRACT_ID=
VITE_PROOF_REGISTRY_CONTRACT_ID=

# Optional: ShieldFund backend API URL (leave blank to use contract reads directly)
VITE_API_BASE_URL=http://localhost:4000
